now_ts() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

now_ts_compact() {
  date -u +%Y%m%d-%H%M%S
}

expand_user_path() {
  local raw="$1"
  case "$raw" in
    "~")
      printf '%s' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s' "$HOME" "${raw#~/}"
      ;;
    *)
      printf '%s' "$raw"
      ;;
  esac
}

execution_mode() {
  if [[ -f "$ROOT_DIR/$INSTALL_MARKER_FILE" ]]; then
    printf 'installed'
  else
    printf 'repo-local'
  fi
}

read_version() {
  local ver=""
  if [[ -f "$VERSION_FILE" ]]; then
    IFS= read -r ver <"$VERSION_FILE" || true
    ver="$(trim "$ver")"
  fi
  if [[ -z "$ver" ]]; then
    ver="0.0.0-unknown"
  fi
  printf '%s' "$ver"
}

capability_summary_line() {
  printf 'x11=full-with-picom+glx wayland=degraded'
}

now_ms() {
  local ms
  ms="$(date +%s%3N 2>/dev/null || true)"
  if [[ -n "$ms" && "$ms" =~ ^[0-9]+$ ]]; then
    printf '%s' "$ms"
  else
    printf '%s000' "$(date +%s)"
  fi
}

hash_string() {
  local text="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$text" | sha256sum | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    printf '%s' "$text" | shasum -a 256 | awk '{print $1}'
  else
    printf '%s' "$text" | cksum | awk '{print $1}'
  fi
}

hash_file() {
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | awk '{print $1}'
  else
    cksum "$file" | awk '{print $1}'
  fi
}

directory_hash() {
  local dir="$1"
  local manifest rel

  [[ -d "$dir" ]] || {
    printf ''
    return 0
  }

  manifest="$(mktemp "$STATE_DIR/hash-manifest.XXXXXX")"
  : >"$manifest"
  while IFS= read -r rel; do
    [[ -f "$dir/$rel" ]] || continue
    printf '%s %s\n' "$(hash_file "$dir/$rel")" "$rel" >>"$manifest"
  done < <(cd "$dir" && find . -type f -printf '%P\n' | sort)
  hash_file "$manifest"
  rm -f "$manifest"
}

write_last_good_checksum() {
  local digest
  if ! dir_has_files "$LAST_GOOD_DIR"; then
    rm -f "$ACTIVE_CHECKSUM_FILE"
    return 1
  fi
  digest="$(directory_hash "$LAST_GOOD_DIR")"
  printf '%s\n' "$digest" >"$ACTIVE_CHECKSUM_FILE"
}

read_last_good_checksum() {
  local digest=""
  if [[ -f "$ACTIVE_CHECKSUM_FILE" ]]; then
    IFS= read -r digest <"$ACTIVE_CHECKSUM_FILE" || true
    digest="$(trim "$digest")"
  fi
  printf '%s' "$digest"
}

reset_loaded_artifact_manifest() {
  MANIFEST_LOAD_ERROR=""
  MANIFEST_VERSION=""
  MANIFEST_GENERATED_AT=""
  MANIFEST_EXECUTION_MODE=""
  MANIFEST_PROFILE_ID=""
  MANIFEST_SESSION_TYPE=""
  MANIFEST_SCOPE_X11=""
  MANIFEST_SCOPE_TTY=""
  MANIFEST_SCOPE_TUIGREET=""
  MANIFEST_COMPOSITOR_REQUIRED=""
  MANIFEST_ARTIFACT_ROOT=""
  MANIFEST_APPLY_INPUT_HASH=""
  MANIFEST_ARTIFACT_ENTRIES=()
  MANIFEST_REQUIRED_RUNTIME_ARTIFACTS=()
  MANIFEST_OPTIONAL_RUNTIME_ARTIFACTS=()
  MANIFEST_EPHEMERAL_RUNTIME_ARTIFACTS=()
  MANIFEST_IGNORED_LOG_OR_CACHE_ARTIFACTS=()
  MANIFEST_EXPORT_ONLY_ARTIFACTS=()
}

artifact_class_known() {
  case "$1" in
    "$ARTIFACT_CLASS_REQUIRED_RUNTIME" | \
    "$ARTIFACT_CLASS_OPTIONAL_RUNTIME" | \
    "$ARTIFACT_CLASS_EPHEMERAL_RUNTIME" | \
    "$ARTIFACT_CLASS_IGNORED_LOG_OR_CACHE" | \
    "$ARTIFACT_CLASS_INSTALL_ASSET" | \
    "$ARTIFACT_CLASS_EXPORT_ONLY")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

artifact_contract_add_entry() {
  local -n ref="$1"
  local class="$2"
  local rel="$3"

  ref+=("$class|$rel")
}

manifest_record_loaded_artifact() {
  local class="$1"
  local rel="$2"
  local entry="$class|$rel"
  local existing

  for existing in "${MANIFEST_ARTIFACT_ENTRIES[@]}"; do
    [[ "$existing" == "$entry" ]] && return 0
  done

  MANIFEST_ARTIFACT_ENTRIES+=("$entry")
  case "$class" in
    "$ARTIFACT_CLASS_REQUIRED_RUNTIME")
      MANIFEST_REQUIRED_RUNTIME_ARTIFACTS+=("$rel")
      ;;
    "$ARTIFACT_CLASS_OPTIONAL_RUNTIME")
      MANIFEST_OPTIONAL_RUNTIME_ARTIFACTS+=("$rel")
      ;;
    "$ARTIFACT_CLASS_EPHEMERAL_RUNTIME")
      MANIFEST_EPHEMERAL_RUNTIME_ARTIFACTS+=("$rel")
      ;;
    "$ARTIFACT_CLASS_IGNORED_LOG_OR_CACHE")
      MANIFEST_IGNORED_LOG_OR_CACHE_ARTIFACTS+=("$rel")
      ;;
    "$ARTIFACT_CLASS_EXPORT_ONLY")
      MANIFEST_EXPORT_ONLY_ARTIFACTS+=("$rel")
      ;;
  esac
}

resolve_runtime_artifact_entries_for_current_profile() {
  local session_type="$1"
  local artifact_root="$2"
  local -n out_ref="$3"
  local rel

  out_ref=()

  for rel in profile.toml profile.env meta "$APPLY_SIG_FILE_NAME"; do
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_REQUIRED_RUNTIME" "$rel"
  done

  for rel in xresources Xresources alacritty.toml semantic.env tty-palette.env tty-palette.txt; do
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_EXPORT_ONLY" "$rel"
  done

  if [[ "$artifact_root" != "stage" && "$CFG_scope_tuigreet" == "true" ]]; then
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_EXPORT_ONLY" "tuigreet.conf"
  fi

  if fonts_requested; then
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_REQUIRED_RUNTIME" "fontconfig.conf"
  fi

  if x11_runtime_artifacts_enabled_for_session "$session_type"; then
    if compositor_required_current_profile; then
      artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_REQUIRED_RUNTIME" "picom.conf"
      artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_REQUIRED_RUNTIME" "shader.glsl"
    else
      artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_OPTIONAL_RUNTIME" "picom.conf"
      artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_OPTIONAL_RUNTIME" "shader.glsl"
    fi
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_EPHEMERAL_RUNTIME" "picom-compat.log"
  fi

  for rel in logs/retrofx.log compat-profile.* compat-stage-* hash-manifest.* tty-backups/*; do
    artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_IGNORED_LOG_OR_CACHE" "$rel"
  done
}

resolve_install_asset_entries() {
  local -n out_ref="$1"

  out_ref=()
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/retrofx"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/test.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/ci.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/i3-retro-session.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/retrofx-runtime-state.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/retrofx-env.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/install-xsession.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/remove-xsession.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "scripts/integrate/generate-xsession.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "backends/x11-picom/apply.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "backends/tty/apply.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "backends/tuigreet/apply.sh"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "templates/shader.glsl.in"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "templates/picom.conf.in"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "templates/xresources.in"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "templates/fontconfig.conf.in"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "profiles/passthrough.toml"
  artifact_contract_add_entry out_ref "$ARTIFACT_CLASS_INSTALL_ASSET" "profiles/packs/core/crt-green-p1-4band.toml"
