declare MANIFEST_PROFILE_ID=""
declare MANIFEST_SESSION_TYPE=""
declare MANIFEST_SCOPE_X11=""
declare MANIFEST_SCOPE_TTY=""
declare MANIFEST_SCOPE_TUIGREET=""
declare MANIFEST_COMPOSITOR_REQUIRED=""
declare MANIFEST_ARTIFACT_ROOT=""
declare MANIFEST_APPLY_INPUT_HASH=""
declare -a MANIFEST_ARTIFACT_ENTRIES=()
declare -a MANIFEST_REQUIRED_RUNTIME_ARTIFACTS=()
declare -a MANIFEST_OPTIONAL_RUNTIME_ARTIFACTS=()
declare -a MANIFEST_EPHEMERAL_RUNTIME_ARTIFACTS=()
declare -a MANIFEST_IGNORED_LOG_OR_CACHE_ARTIFACTS=()
declare -a MANIFEST_EXPORT_ONLY_ARTIFACTS=()
declare -a ARTIFACT_CHECK_MISSING=()
declare -a ARTIFACT_CHECK_INVALID=()
declare -a INSTALL_ASSET_CHECK_MISSING=()
declare -a INSTALL_ASSET_CHECK_INVALID=()

